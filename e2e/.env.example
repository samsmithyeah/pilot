# Copy this file to `.env` and fill in values as needed.
# Variables already set in your shell or CI environment take precedence
# over .env, so you can override per-run without editing this file.

# Path to the prebuilt TapsmithAgent xctestrun. If unset, the iOS config
# auto-discovers the most recently built one in Xcode's DerivedData
# (~/Library/Developer/Xcode/DerivedData/TapsmithAgent-*/Build/Products/).
# Set this explicitly if you have multiple builds around or want CI to
# use a fixed path.
# TAPSMITH_IOS_XCTESTRUN=/Users/you/Library/Developer/Xcode/DerivedData/TapsmithAgent-xxxxx/Build/Products/TapsmithAgentUITests_TapsmithAgentUITests_iphonesimulator26.4-arm64.xctestrun

# Simulator name to run iOS tests against. Defaults to "iPhone 17".
# TAPSMITH_IOS_SIMULATOR=iPhone 17
